# ClearIntent operator secrets template.
# Copy this file outside the repo before filling values:
# ~/.clearintent/clearintent.secrets.env

# Phase 2B: funded 0G testnet wallet.
ZERO_G_WALLET_ADDRESS=
ZERO_G_PRIVATE_KEY=

# Phase 4B: KeeperHub or execution provider token, if required by the live adapter.
KEEPERHUB_API_TOKEN=

# Optional: paid/private RPC URLs if a future live phase requires them.
PRIVATE_EVM_RPC_URL=

# Optional Phase 3B ENS record submission key.
# Use only a dedicated demo/parent wallet that controls the target ENS name.
ENS_SIGNER_PRIVATE_KEY=
