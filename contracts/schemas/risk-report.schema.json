{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clearintent.local/contracts/schemas/risk-report.schema.json",
  "title": "RiskReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportId",
    "intentHash",
    "policyHash",
    "decision",
    "severity",
    "reasons",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "clearintent.risk-report.v1" },
    "reportId": { "type": "string", "minLength": 1 },
    "intentHash": { "$ref": "#/$defs/bytes32" },
    "policyHash": { "$ref": "#/$defs/bytes32" },
    "decision": { "type": "string", "enum": ["allow", "block", "needs_human_review"] },
    "severity": { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "degradedSignals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "bytes32": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    }
  }
}
