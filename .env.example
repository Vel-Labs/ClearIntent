# ClearIntent local runtime configuration example.
# Copy to .env.local for non-secret local runtime config.
# Real wallet keys and provider tokens belong outside the repo in:
# ~/.clearintent/clearintent.secrets.env

# Phase 2A default. Set to live only for Phase 2B smoke checks.
ZERO_G_PROVIDER_MODE=local

# 0G Galileo testnet defaults used by the Phase 2B readiness preflight.
ZERO_G_EVM_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_STORAGE_MODE=turbo

# Live writes stay disabled until you intentionally opt in after funding the wallet.
ZERO_G_ENABLE_LIVE_WRITES=false

# Optional: request proof-enabled download during live smoke. Leave false for first write/read test.
ZERO_G_REQUIRE_PROOF=false

# Phase 3B live ENS read/binding. Public RPC values can live here; paid/private RPCs
# should use PRIVATE_EVM_RPC_URL in the external operator secrets file instead.
ENS_PROVIDER_RPC=
# Backward-compatible alias consumed by identity live-status when ENS_PROVIDER_RPC is blank.
ENS_EVM_RPC=
ENS_CHAIN_ID=1
ENS_NETWORK=mainnet
ENS_NAME=
# Backward-compatible alias consumed by identity live-status when ENS_NAME is blank.
CLEARINTENT_ENS_NAME=
ENS_EXPECTED_POLICY_HASH=
# Backward-compatible alias consumed by identity live-status when ENS_EXPECTED_POLICY_HASH is blank.
CLEARINTENT_EXPECTED_POLICY_HASH=

# Phase 3B ENS text-record binding transaction preparation. These values are public
# 0G/ENS references generated by `memory live-bindings`; they are not secrets.
ENS_RESOLVER_ADDRESS=
CLEARINTENT_AGENT_CARD_URI=
CLEARINTENT_POLICY_URI=
CLEARINTENT_AUDIT_LATEST=
CLEARINTENT_POLICY_HASH=
CLEARINTENT_VERSION=0.1.0
# Gated ENS record submission. Keep false unless intentionally submitting the
# prepared Public Resolver multicall from a demo/parent wallet.
ENS_ENABLE_LIVE_WRITES=false

# Phase 4B KeeperHub live readiness. Secrets belong in the external operator
# secrets file; workflow IDs and gates can live here.
KEEPERHUB_API_BASE_URL=https://app.keeperhub.com/api
KEEPERHUB_EXECUTION_MODE=workflow
KEEPERHUB_WORKFLOW_ID=
# Execution/run ID returned by keeperhub live-submit; used by keeperhub live-run-status.
KEEPERHUB_EXECUTION_ID=
KEEPERHUB_PROJECT_ID=
KEEPERHUB_ORG_ID=
KEEPERHUB_EXECUTOR_ADDRESS=
# Safe read-only probe. When true, keeperhub live-status may GET the workflow.
KEEPERHUB_ENABLE_LIVE_PROBE=false
# Live submit can execute the selected KeeperHub workflow. Keep false unless
# intentionally running Phase 4B live-submit.
KEEPERHUB_ENABLE_LIVE_SUBMIT=false

# Phase 6 frontend / Alchemy Account Kit readiness. These are public frontend
# configuration values only; they do not prove smart-account/session-key
# enforcement. Gas sponsorship is intentionally not required for the current
# parent-owned agent smart account path.
NEXT_PUBLIC_CLEARINTENT_ENS_NAME=
NEXT_PUBLIC_ALCHEMY_CHAIN=sepolia
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_ALCHEMY_WALLET_CONFIG_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_KEEPERHUB_WORKFLOW_ID=

# Optional override for the external operator secrets file.
# Leave blank to use clearintent.config.json default:
# ~/.clearintent/clearintent.secrets.env
CLEARINTENT_SECRETS_FILE=
