# ClearIntent local environment example.
# Copy to .env.local for local use. Do not commit real private keys or tokens.

# Phase 2A default. Set to live only for Phase 2B smoke checks.
ZERO_G_PROVIDER_MODE=local

# 0G Galileo testnet defaults used by the Phase 2B readiness preflight.
ZERO_G_EVM_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_STORAGE_MODE=turbo

# Optional public address for audit/runbook clarity.
ZERO_G_WALLET_ADDRESS=

# Required only for live upload/read smoke tests. Keep this in .env.local only.
ZERO_G_PRIVATE_KEY=

# Live writes stay disabled until you intentionally opt in after funding the wallet.
ZERO_G_ENABLE_LIVE_WRITES=false
